---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
    transparentHeader?: boolean;
}

const {
    title = 'Messy Careers',
    description = 'Career coaching services for ambitious professionals',
    transparentHeader = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon-icon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <title>{title}</title>
    </head>
    <body class="min-h-screen bg-background font-sans text-foreground">
        <header
            id="site-header"
            data-transparent={transparentHeader ? 'true' : 'false'}
            class="fixed top-0 left-0 right-0 z-50 p-2 transition-all duration-300"
        >
            <div
                class="container mx-auto px-3 py-3 md:px-6 md:py-4 flex items-center justify-between"
            >
                <a href="/">
                    <img
                        id="site-logo"
                        src="/favicon.svg"
                        alt="Messy Careers"
                        class="h-5 md:h-6 w-auto transition-all duration-300"
                    />
                </a>
                <nav class="flex items-center gap-3 sm:gap-6 md:gap-8">
                    <a
                        class="nav-link hidden sm:block font-sans font-bold text-sm md:text-base transition-colors"
                        href="/about"
                    >
                        About
                    </a>
                    <a
                        class="nav-link hidden sm:block font-sans font-bold text-sm md:text-base transition-colors"
                        href="/services"
                    >
                        Programs
                    </a>
                    <a
                        class="nav-link hidden sm:block font-sans font-bold text-sm md:text-base transition-colors"
                        href="/reviews"
                    >
                        Stories
                    </a>
                    <a
                        class="nav-cta font-sans font-bold text-sm px-4 sm:px-5 py-2 sm:py-2.5 rounded-full transition-all"
                        href="/intro-call"
                    >
                        Let's talk
                    </a>
                </nav>
            </div>
        </header>

        <style>
            /* Default (solid) header state */
            #site-header {
                background-color: rgba(255, 253, 233, 0.95);
                backdrop-filter: blur(4px);
                border-bottom: 1px solid #86AFFA;
            }
            #site-logo {
                filter: none;
            }
            .nav-link {
                color: #1023CE;
            }
            .nav-link:hover {
                color: #1023CE;
                opacity: 0.7;
            }
            .nav-cta {
                background-color: #1023CE;
                color: #FFFDE9;
            }
            .nav-cta:hover {
                opacity: 0.85;
            }

            /* Transparent header state */
            #site-header[data-transparent="true"] {
                background-color: transparent;
                backdrop-filter: none;
                border-bottom: 1px solid transparent;
            }
            #site-header[data-transparent="true"] #site-logo {
                filter: brightness(0) invert(1);
            }
            #site-header[data-transparent="true"] .nav-link {
                color: white;
            }
            #site-header[data-transparent="true"] .nav-link:hover {
                color: white;
                opacity: 0.7;
            }
            #site-header[data-transparent="true"] .nav-cta {
                background-color: white;
                color: #1023CE;
            }
            #site-header[data-transparent="true"] .nav-cta:hover {
                opacity: 0.9;
            }
        </style>

        <main class={!transparentHeader ? 'pt-20' : ''}>
            {!transparentHeader && (
                <a
                    href="/"
                    class="fixed left-6 bottom-6 z-50 inline-flex items-center gap-1.5 font-sans text-xs font-bold bg-background border border-border text-primary/50 hover:text-primary hover:border-primary px-4 py-2.5 rounded-full shadow-sm transition-all uppercase tracking-wider"
                >
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                    Home
                </a>
            )}
            <slot />
        </main>

        {transparentHeader && (
            <script>
                const header = document.getElementById('site-header');

                function updateHeader() {
                    const heroHeight = window.innerHeight;
                    const scrolled = window.scrollY > heroHeight * 0.1;
                    header?.setAttribute('data-transparent', scrolled ? 'false' : 'true');
                }

                window.addEventListener('scroll', updateHeader, { passive: true });
                updateHeader();
            </script>
        )}

        <footer class="py-16 bg-foreground text-background">
            <div class="container mx-auto px-5 sm:px-6">
                <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-8 sm:gap-10 mb-10 sm:mb-12">
                    <!-- Logo + badge -->
                    <div class="flex flex-col items-center md:items-start gap-5">
                        <img
                            src="/favicon.svg"
                            alt="Messy Careers"
                            class="w-28 sm:w-36 brightness-0 invert"
                        />
                        <div class="inline-flex items-center gap-2.5 border border-background/20 rounded-xl px-3.5 py-2.5">
                            <div class="flex flex-col items-center leading-none">
                                <span class="font-sans text-[9px] font-bold uppercase tracking-widest text-background/40">ICF</span>
                                <span class="font-serif text-base text-background/70 leading-none">ACC</span>
                            </div>
                            <div class="w-px h-7 bg-background/15"></div>
                            <div class="flex flex-col leading-none gap-0.5">
                                <span class="font-sans text-[9px] font-bold uppercase tracking-widest text-background/40">Certified</span>
                                <span class="font-sans text-[9px] font-bold uppercase tracking-widest text-background/40">Coach</span>
                            </div>
                            <div class="w-px h-7 bg-background/15"></div>
                            <div class="flex flex-col leading-none gap-0.5">
                                <span class="font-sans text-[9px] font-bold uppercase tracking-widest text-background/40">ICF</span>
                                <span class="font-sans text-[9px] font-bold uppercase tracking-widest text-background/40">Member</span>
                            </div>
                        </div>
                    </div>
                    <!-- Nav links -->
                    <div class="flex flex-row gap-6 sm:gap-10 text-left">
                        <div class="flex flex-col gap-3 min-w-0">
                            <p class="font-sans text-xs font-bold uppercase tracking-wider text-background/40 mb-1">Site</p>
                            <a href="/about" class="font-sans text-sm text-background/70 hover:text-background transition-colors">About</a>
                            <a href="/services" class="font-sans text-sm text-background/70 hover:text-background transition-colors">Programs</a>
                            <a href="/reviews" class="font-sans text-sm text-background/70 hover:text-background transition-colors">Stories</a>
                        </div>
                        <div class="flex flex-col gap-3 min-w-0">
                            <p class="font-sans text-xs font-bold uppercase tracking-wider text-background/40 mb-1">Contact</p>
                            <a href="/intro-call" class="font-sans text-sm text-background/70 hover:text-background transition-colors">Book an intro call</a>
                            <a href="mailto:hello@katemas.me" class="inline-flex items-center gap-2 font-sans text-sm text-background/70 hover:text-background transition-colors">
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
                                hello@katemas.me
                            </a>
                            <a href="https://www.linkedin.com/in/kate-mas" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 font-sans text-sm text-background/70 hover:text-background transition-colors">
                                <svg class="w-4 h-4" role="img" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                LinkedIn
                            </a>
                            <p class="inline-flex items-center gap-1.5 font-sans text-sm text-background/40">
                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                                Paris, France
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Bottom bar -->
                <div class="border-t border-background/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
                    <p class="font-sans text-xs text-background/40">
                        &copy; {new Date().getFullYear()} Kate Mas. All rights reserved.
                    </p>
                    <a href="/terms" class="font-sans text-xs text-background/40 hover:text-background/70 transition-colors">
                        Terms of Service
                    </a>
                </div>
            </div>
        </footer>
    </body>
</html>
